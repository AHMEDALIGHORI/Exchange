# Frontend (Vite) — safe to commit without secrets
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key
VITE_PINATA_JWT=your_pinata_jwt

# Populated after `npm run deploy:sepolia` (or set manually)
VITE_EXC_TOKEN_ADDRESS=
VITE_WEX_TOKEN_ADDRESS=
VITE_SIMPLE_NFT_ADDRESS=
VITE_STAKING_POOL_ADDRESS=
VITE_SIMPLE_SWAP_ADDRESS=
VITE_BANK_POLICY_REGISTRY_ADDRESS=
VITE_BANK_DEPOSIT_TOKEN_ADDRESS=

# Optional
# VITE_WALLET_CONNECT_PROJECT_ID=

# Hardhat deploy (NEVER commit real keys — use contracts/.env locally)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# DEPLOYER_PRIVATE_KEY=your_testnet_private_key_without_0x_prefix_or_with
